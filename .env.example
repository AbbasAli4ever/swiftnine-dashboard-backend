# Database (used by docker-compose)
POSTGRES_USER=focushub
POSTGRES_PASSWORD=focushub123
POSTGRES_DB=focushub
DB_PORT=5432

# Prisma (used by app and prisma CLI)
DATABASE_URL="postgresql://focushub:focushub123@localhost:5432/focushub?schema=public"

# App
PORT=3002
NODE_ENV=development

# Logging: 'full' = request/response + app logs, 'app' = app-level only
LOG_LEVEL=full

# CORS
CORS_ORIGINS=http://localhost:3000
CORS_ALLOW_CREDENTIALS=true

# Refresh-token cookie scope.
# Leave both blank in dev (host-only cookie, SameSite=Lax).
# In prod with frontend/backend on different subdomains of the same parent,
# set COOKIE_DOMAIN to the parent (e.g. .swiftnine.com) and COOKIE_SAMESITE=none.
# SameSite=None requires Secure, which is enforced automatically.
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax

# Prisma Studio
PRISMA_STUDIO_PORT=5555

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3002/api/v1/auth/google/callback

# For sending emails (e.g., password reset)
RESEND_API_KEY=re_xxxx
FRONTEND_URL=http://localhost:3000
