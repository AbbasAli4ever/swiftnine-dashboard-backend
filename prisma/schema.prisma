// ============================================================
// FocusHub V1 - Prisma Schema
// Database: PostgreSQL
// ============================================================

generator client {
  provider     = "prisma-client"
  output       = "../libs/database/src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceUse {
  WORK
  PERSONAL
  SCHOOL
}

enum WorkspaceManagementType {
  HR_RECRUITING
  CREATIVE_DESIGN
  PROFESSIONAL_SERVICES
  FINANCE_ACCOUNTING
  OPERATIONS
  SOFTWARE_DEVELOPMENT
  IT
  SALES_CRM
  PERSONAL_USE
  SUPPORT
  STARTUP
  PMO
  MARKETING
  OTHER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum Priority {
  URGENT
  HIGH
  NORMAL
  LOW
  NONE
}

enum StatusGroup {
  NOT_STARTED
  ACTIVE
  DONE
  CLOSED
}

// ============================================================
// MODELS
// ============================================================

/// Core user account — profile, auth, online status
model User {
  id                      String    @id @default(uuid())
  fullName                String    @map("full_name")
  email                   String    @unique
  passwordHash            String?   @map("password_hash")
  googleId                String?   @unique @map("google_id")
  avatarUrl               String?   @map("avatar_url")
  avatarColor             String    @default("#6366f1") @map("avatar_color")
  designation             String?
  bio                     String?
  isOnline                Boolean   @default(false) @map("is_online")
  lastSeenAt              DateTime? @map("last_seen_at")
  timezone                String?
  notificationPreferences Json      @default("{}") @map("notification_preferences")
  isEmailVerified         Boolean   @default(false) @map("is_email_verified")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")
  deletedAt               DateTime? @map("deleted_at")

  // Relations
  refreshTokens              RefreshToken[]
  passwordResetTokens        PasswordResetToken[]
  emailVerificationTokens    EmailVerificationToken[]
  workspacesCreated          Workspace[]              @relation("WorkspaceCreator")
  workspaceMembers           WorkspaceMember[]
  projectFavorites           ProjectFavorite[]
  taskFavorites              TaskFavorite[]
  channelMembers             ChannelMember[]
  channelMessagesSent        ChannelMessage[]         @relation("ChannelMessageSender")
  channelMessagesPinned      ChannelMessage[]         @relation("ChannelMessagePinner")
  channelMessageMentions     ChannelMessageMention[]
  channelMessageReactions    ChannelMessageReaction[]
  channelJoinRequestsMade    ChannelJoinRequest[]     @relation("JoinRequester")
  channelJoinRequestsDecided ChannelJoinRequest[]     @relation("JoinRequestDecider")
  workspaceInvitesSent       WorkspaceInvite[]        @relation("InviteSender")
  projectsCreated            Project[]                @relation("ProjectCreator")
  taskListsCreated           TaskList[]               @relation("TaskListCreator")
  taskListsOwned             TaskList[]               @relation("TaskListOwner")
  tasksCreated               Task[]                   @relation("TaskCreator")
  taskAssignments            TaskAssignee[]           @relation("AssignedUser")
  taskAssignmentsMade        TaskAssignee[]           @relation("AssignedByUser")
  comments                   Comment[]
  mentions                   Mention[]
  notificationsReceived      Notification[]           @relation("NotificationRecipient")
  notificationsTriggered     Notification[]           @relation("NotificationActor")
  attachmentsUploaded        Attachment[]
  timeEntries                TimeEntry[]
  activityLogs               ActivityLog[]
  docsOwned                  Doc[]                    @relation("DocOwner")
  docVersionsCreated         DocVersion[]             @relation("DocVersionCreator")
  docPermissionsGranted      DocPermission[]          @relation("DocPermissionGranter")
  docPermissionsReceived     DocPermission[]          @relation("DocPermissionGrantee")
  docThreadsCreated          DocCommentThread[]       @relation("DocThreadCreator")
  docCommentsAuthored        DocComment[]             @relation("DocCommentAuthor")
  docShareLinksCreated       DocShareLink[]           @relation("DocShareLinkCreator")

  @@map("users")
}

/// Hashed refresh tokens for JWT auth — one user can have multiple sessions
model RefreshToken {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  tokenHash  String   @unique @map("token_hash")
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt  DateTime @map("expires_at")
  isRevoked  Boolean  @default(false) @map("is_revoked")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

/// Short-lived token for password reset via email link — one active token per user
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tokenHash String   @unique @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

/// Short-lived OTP for email verification on sign-up — one active token per user
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  otpHash   String   @unique @map("otp_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

/// Top-level organizational container — users can belong to multiple
model Workspace {
  id             String                  @id @default(uuid())
  name           String
  logoUrl        String?                 @map("logo_url")
  workspaceUse   WorkspaceUse            @map("workspace_use")
  managementType WorkspaceManagementType @map("management_type")
  createdBy      String                  @map("created_by")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  deletedAt      DateTime?               @map("deleted_at")

  // Relations
  creator          User              @relation("WorkspaceCreator", fields: [createdBy], references: [id])
  members          WorkspaceMember[]
  invites          WorkspaceInvite[]
  projects         Project[]
  channels         Channel[]
  tags             Tag[]
  activityLogs     ActivityLog[]
  docs             Doc[]
  projectFavorites ProjectFavorite[]
  taskFavorites    TaskFavorite[]
  notifications    Notification[]

  @@map("workspaces")
}

/// Junction: User <-> Workspace with role assignment
model WorkspaceMember {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  userId      String    @map("user_id")
  role        Role      @default(MEMBER)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  workspace Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions Reaction[]

  @@unique([workspaceId, userId])
  @@index([userId])
  @@map("workspace_members")
}

/// Pending email invitations — token expires after 7 days
model WorkspaceInvite {
  id          String       @id @default(uuid())
  workspaceId String       @map("workspace_id")
  email       String
  role        Role         @default(MEMBER)
  inviteToken String       @unique @map("invite_token")
  invitedBy   String       @map("invited_by")
  status      InviteStatus @default(PENDING)
  expiresAt   DateTime     @map("expires_at")
  acceptedAt  DateTime?    @map("accepted_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sender    User      @relation("InviteSender", fields: [invitedBy], references: [id])

  @@index([workspaceId, email, status])
  @@map("workspace_invites")
}

/// Projects (Spaces) — lives inside a workspace, has own statuses and task counter
model Project {
  id           String    @id @default(uuid())
  workspaceId  String    @map("workspace_id")
  name         String
  description  String?
  color        String    @default("#6366f1")
  icon         String?
  taskIdPrefix String    @map("task_id_prefix")
  taskCounter  Int       @default(0) @map("task_counter")
  isArchived   Boolean   @default(false) @map("is_archived")
  createdBy    String    @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Relations
  workspace Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creator   User              @relation("ProjectCreator", fields: [createdBy], references: [id])
  channels  Channel[]
  taskLists TaskList[]
  statuses  Status[]
  docs      Doc[]
  favorites ProjectFavorite[]

  @@unique([workspaceId, taskIdPrefix])
  @@index([workspaceId])
  @@map("projects")
}

/// Task lists inside a project — gap-based positioning
model TaskList {
  id          String    @id @default(uuid())
  projectId   String    @map("project_id")
  name        String
  position    Int       @default(1000)
  startDate   DateTime? @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  ownerUserId String?   @map("owner_user_id")
  priority    Priority?
  isArchived  Boolean   @default(false) @map("is_archived")
  createdBy   String    @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User    @relation("TaskListCreator", fields: [createdBy], references: [id])
  owner   User?   @relation("TaskListOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks   Task[]

  @@index([projectId, position])
  @@index([ownerUserId])
  @@map("task_lists")
}

/// Custom statuses per project — 4 defaults auto-created on project creation
model Status {
  id          String      @id @default(uuid())
  projectId   String      @map("project_id")
  name        String
  color       String      @default("#94a3b8")
  position    Int         @default(1000)
  group       StatusGroup @default(ACTIVE)
  isDefault   Boolean     @default(false) @map("is_default")
  isProtected Boolean     @default(false) @map("is_protected")
  isClosed    Boolean     @default(false) @map("is_closed")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  // Relations
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([projectId, name])
  @@index([projectId, group, position])
  @@map("statuses")
}

/// Workspace-scoped tags applied to tasks
model Tag {
  id          String    @id @default(uuid())
  workspaceId String    @map("workspace_id")
  name        String
  color       String    @default("#6366f1")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  taskTags  TaskTag[]

  @@unique([workspaceId, name])
  @@map("tags")
}

/// Core task entity — self-referencing for subtasks (max depth 2)
model Task {
  id                   String    @id @default(uuid())
  listId               String    @map("list_id")
  parentId             String?   @map("parent_id")
  depth                Int       @default(0)
  title                String
  description          String?
  descriptionJson      Json?     @map("description_json")
  descriptionPlaintext String?   @map("description_plaintext")
  statusId             String    @map("status_id")
  priority             Priority  @default(NONE)
  taskNumber           Int       @map("task_number")
  startDate            DateTime? @map("start_date")
  dueDate              DateTime? @map("due_date")
  position             Int       @default(1000)
  boardPosition        Int       @default(1000) @map("board_position")
  isCompleted          Boolean   @default(false) @map("is_completed")
  completedAt          DateTime? @map("completed_at")
  createdBy            String    @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  // Relations
  list        TaskList       @relation(fields: [listId], references: [id], onDelete: Cascade)
  parent      Task?          @relation("TaskSubtasks", fields: [parentId], references: [id], onDelete: Cascade)
  children    Task[]         @relation("TaskSubtasks")
  status      Status         @relation(fields: [statusId], references: [id])
  creator     User           @relation("TaskCreator", fields: [createdBy], references: [id])
  assignees   TaskAssignee[]
  tags        TaskTag[]
  comments    Comment[]
  attachments Attachment[]
  timeEntries TimeEntry[]
  favorites   TaskFavorite[]

  @@index([listId, position])
  @@index([listId, parentId, position])
  @@index([statusId])
  @@index([statusId, boardPosition])
  @@index([dueDate])
  @@map("tasks")
}

/// User-specific favorite projects for quick access/starred views
model ProjectFavorite {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  projectId   String   @map("project_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@index([workspaceId, userId, createdAt])
  @@index([projectId])
  @@map("project_favorites")
}

/// User-specific favorite tasks for quick access/starred views
model TaskFavorite {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  taskId      String   @map("task_id")
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([userId, taskId])
  @@index([workspaceId, userId, createdAt])
  @@index([taskId])
  @@map("task_favorites")
}

/// Junction: Task <-> User for multi-assignee support
model TaskAssignee {
  id         String   @id @default(uuid())
  taskId     String   @map("task_id")
  userId     String   @map("user_id")
  assignedBy String   @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  task     Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user     User @relation("AssignedUser", fields: [userId], references: [id])
  assigner User @relation("AssignedByUser", fields: [assignedBy], references: [id])

  @@unique([taskId, userId])
  @@index([userId])
  @@map("task_assignees")
}

/// Junction: Task <-> Tag
model TaskTag {
  id        String   @id @default(uuid())
  taskId    String   @map("task_id")
  tagId     String   @map("tag_id")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
  @@map("task_tags")
}

/// Task comments with threading — parent deletion cascades to replies
model Comment {
  id        String    @id @default(uuid())
  taskId    String    @map("task_id")
  userId    String    @map("user_id")
  parentId  String?   @map("parent_id")
  content   String
  isEdited  Boolean   @default(false) @map("is_edited")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  task      Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User       @relation(fields: [userId], references: [id])
  parent    Comment?   @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies   Comment[]  @relation("CommentReplies")
  mentions  Mention[]
  reactions Reaction[]

  @@index([taskId, createdAt])
  @@map("comments")
}

/// Reactions on comments (one reaction belongs to one comment)
model Reaction {
  id        String   @id @default(uuid())
  commentId String   @map("comment_id")
  memberId  String   @map("member_id")
  reactFace String   @default("") @map("react_face")
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  comment Comment         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  member  WorkspaceMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([commentId, memberId, reactFace])
  @@index([commentId])
  @@index([memberId])
  @@map("reactions")
}

/// @mentions in comments — used for notification targeting
model Mention {
  id              String   @id @default(uuid())
  commentId       String   @map("comment_id")
  mentionedUserId String   @map("mentioned_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  // Relations
  comment       Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  mentionedUser User    @relation(fields: [mentionedUserId], references: [id])

  @@unique([commentId, mentionedUserId])
  @@map("mentions")
}

/// In-app notifications — polymorphic reference, auto-cleaned after 90 days
model Notification {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  workspaceId   String    @map("workspace_id")
  type          String
  title         String
  message       String?
  referenceType String    @map("reference_type")
  referenceId   String    @map("reference_id")
  actorId       String?   @map("actor_id")
  isRead        Boolean   @default(false) @map("is_read")
  readAt        DateTime? @map("read_at")
  isCleared     Boolean   @default(false) @map("is_cleared")
  isSnoozed     Boolean   @default(false) @map("is_snoozed")
  snoozedAt     DateTime? @map("snoozed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  // Relations
  recipient   User      @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actor       User?     @relation("NotificationActor", fields: [actorId], references: [id])
  isCommented Boolean   @default(false) @map("is_commented")

  @@index([userId, isRead, isCleared, isSnoozed, createdAt])
  @@index([workspaceId, userId])
  @@map("notifications")
}

/// File attachments on tasks or docs — stored in AWS S3
model Attachment {
  id               String    @id @default(uuid())
  taskId           String?   @map("task_id")
  docId            String?   @map("doc_id")
  channelMessageId String?   @map("channel_message_id")
  uploadedBy       String    @map("uploaded_by")
  fileName         String    @map("file_name")
  s3Key            String    @unique @map("s3_key")
  mimeType         String    @map("mime_type")
  fileSize         BigInt    @map("file_size")
  createdAt        DateTime  @default(now()) @map("created_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  task           Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  doc            Doc?            @relation(fields: [docId], references: [id], onDelete: Cascade)
  channelMessage ChannelMessage? @relation(fields: [channelMessageId], references: [id], onDelete: Cascade)
  uploader       User            @relation(fields: [uploadedBy], references: [id])

  @@index([taskId])
  @@index([docId])
  @@index([channelMessageId])
  @@map("attachments")
}

/// Time tracking — manual logging + timer-based
model TimeEntry {
  id          String    @id @default(uuid())
  taskId      String    @map("task_id")
  userId      String    @map("user_id")
  description String?
  startTime   DateTime  @map("start_time")
  endTime     DateTime? @map("end_time")
  duration    Int?
  isManual    Boolean   @default(false) @map("is_manual")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId, userId])
  @@map("time_entries")
}

/// Central audit trail — append-only, no updates, no deletes
model ActivityLog {
  id          String   @id @default(uuid())
  workspaceId String   @map("workspace_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  fieldName   String?  @map("field_name")
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  metadata    Json     @default("{}")
  performedBy String   @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  workspace Workspace @relation(fields: [workspaceId], references: [id])
  performer User      @relation(fields: [performedBy], references: [id])

  @@index([entityType, entityId])
  @@index([workspaceId, createdAt])
  @@index([performedBy, createdAt])
  @@map("activity_logs")
}

// Channels (chat/discussion spaces inside workspace, optionally scoped to a project)
enum ChannelPrivacy {
  PUBLIC
  PRIVATE
}

enum ChannelKind {
  CHANNEL
  DM
}

enum ChannelMessageKind {
  USER
  SYSTEM
}

enum ChannelJoinRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model Channel {
  id          String         @id @default(uuid())
  workspaceId String         @map("workspace_id")
  projectId   String?        @map("project_id")
  name        String?
  description String?
  kind        ChannelKind    @default(CHANNEL)
  privacy     ChannelPrivacy @default(PUBLIC)
  createdBy   String         @map("created_by")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  workspace    Workspace            @relation(fields: [workspaceId], references: [id])
  project      Project?             @relation(fields: [projectId], references: [id])
  members      ChannelMember[]
  messages     ChannelMessage[]
  joinRequests ChannelJoinRequest[]

  @@index([workspaceId])
  @@index([workspaceId, kind])
  @@index([projectId])
  @@map("channels")
}

model ChannelMember {
  id                String   @id @default(uuid())
  channelId         String   @map("channel_id")
  userId            String   @map("user_id")
  role              Role     @default(MEMBER)
  isMuted           Boolean  @default(false) @map("is_muted")
  lastReadMessageId String?  @map("last_read_message_id")
  unreadCount       Int      @default(0) @map("unread_count")
  joinedAt          DateTime @default(now()) @map("joined_at")
  createdAt         DateTime @default(now()) @map("created_at")

  // Relations
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([channelId, userId])
  @@index([userId])
  @@index([userId, channelId])
  @@map("channel_members")
}

model ChannelMessage {
  id               String             @id @default(uuid())
  channelId        String             @map("channel_id")
  senderId         String?            @map("sender_id")
  kind             ChannelMessageKind @default(USER)
  contentJson      Json               @map("content_json")
  plaintext        String             @default("")
  replyToMessageId String?            @map("reply_to_message_id")
  isEdited         Boolean            @default(false) @map("is_edited")
  editedAt         DateTime?          @map("edited_at")
  isPinned         Boolean            @default(false) @map("is_pinned")
  pinnedAt         DateTime?          @map("pinned_at")
  pinnedById       String?            @map("pinned_by_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  deletedAt        DateTime?          @map("deleted_at")

  channel     Channel                  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender      User?                    @relation("ChannelMessageSender", fields: [senderId], references: [id])
  pinnedBy    User?                    @relation("ChannelMessagePinner", fields: [pinnedById], references: [id])
  replyTo     ChannelMessage?          @relation("ChannelMessageReply", fields: [replyToMessageId], references: [id], onDelete: SetNull)
  replies     ChannelMessage[]         @relation("ChannelMessageReply")
  mentions    ChannelMessageMention[]
  reactions   ChannelMessageReaction[]
  attachments Attachment[]

  @@index([channelId, createdAt(sort: Desc), id])
  @@index([channelId, isPinned, createdAt])
  @@index([senderId])
  @@map("channel_messages")
}

model ChannelMessageMention {
  id              String   @id @default(uuid())
  messageId       String   @map("message_id")
  mentionedUserId String   @map("mentioned_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  message       ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  mentionedUser User           @relation(fields: [mentionedUserId], references: [id])

  @@unique([messageId, mentionedUserId])
  @@index([mentionedUserId])
  @@map("channel_message_mentions")
}

model ChannelMessageReaction {
  id        String   @id @default(uuid())
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  message ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@map("channel_message_reactions")
}

model ChannelJoinRequest {
  id          String                   @id @default(uuid())
  channelId   String                   @map("channel_id")
  userId      String                   @map("user_id")
  status      ChannelJoinRequestStatus @default(PENDING)
  requestedAt DateTime                 @default(now()) @map("requested_at")
  decidedById String?                  @map("decided_by_id")
  decidedAt   DateTime?                @map("decided_at")

  channel   Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User    @relation("JoinRequester", fields: [userId], references: [id])
  decidedBy User?   @relation("JoinRequestDecider", fields: [decidedById], references: [id])

  @@unique([channelId, userId, status])
  @@index([channelId, status])
  @@map("channel_join_requests")
}

// ============================================================
// DOCS FEATURE
// ============================================================

enum DocScope {
  WORKSPACE
  PROJECT
  PERSONAL
}

enum DocRole {
  VIEWER
  COMMENTER
  EDITOR
  OWNER
}

enum DocVersionType {
  AUTO
  MANUAL
  RESTORE_SAFETY
}

/// A document — belongs to a workspace, optionally a project, always has an owner
model Doc {
  id               String    @id @default(uuid())
  workspaceId      String    @map("workspace_id")
  projectId        String?   @map("project_id")
  ownerId          String    @map("owner_id")
  scope            DocScope
  title            String
  contentJson      Json      @default("{}") @map("content_json")
  plaintext        String    @default("") // denormalized text extracted from contentJson for full-text search
  version          Int       @default(0)
  lastCheckpointAt DateTime? @map("last_checkpoint_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  // Relations
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner       User               @relation("DocOwner", fields: [ownerId], references: [id])
  versions    DocVersion[]
  permissions DocPermission[]
  threads     DocCommentThread[]
  shareLinks  DocShareLink[]
  attachments Attachment[]

  @@index([workspaceId, scope, deletedAt])
  @@index([projectId])
  @@index([ownerId])
  @@map("docs")
}

/// Point-in-time snapshot of a Doc — auto every 20 min or manual by user
model DocVersion {
  id          String         @id @default(uuid())
  docId       String         @map("doc_id")
  contentJson Json           @map("content_json")
  type        DocVersionType
  label       String?
  createdAt   DateTime       @default(now()) @map("created_at")
  createdById String         @map("created_by_id")

  // Relations
  doc       Doc  @relation(fields: [docId], references: [id], onDelete: Cascade)
  createdBy User @relation("DocVersionCreator", fields: [createdById], references: [id])

  @@index([docId, createdAt])
  @@map("doc_versions")
}

/// Per-doc role override — supplements inherited workspace/project role
model DocPermission {
  id          String   @id @default(uuid())
  docId       String   @map("doc_id")
  userId      String   @map("user_id")
  role        DocRole
  grantedById String   @map("granted_by_id")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  doc       Doc  @relation(fields: [docId], references: [id], onDelete: Cascade)
  user      User @relation("DocPermissionGrantee", fields: [userId], references: [id])
  grantedBy User @relation("DocPermissionGranter", fields: [grantedById], references: [id])

  @@unique([docId, userId])
  @@index([userId])
  @@map("doc_permissions")
}

/// A comment thread anchored to a block selection or the doc as a whole
model DocCommentThread {
  id            String   @id @default(uuid())
  docId         String   @map("doc_id")
  anchorBlockId String?  @map("anchor_block_id")
  anchorMeta    Json?    @map("anchor_meta") // { charStart, charEnd } — null when doc-level or orphaned
  resolved      Boolean  @default(false)
  isOrphan      Boolean  @default(false) @map("is_orphan")
  createdById   String   @map("created_by_id")
  createdAt     DateTime @default(now()) @map("created_at")

  // Relations
  doc       Doc          @relation(fields: [docId], references: [id], onDelete: Cascade)
  createdBy User         @relation("DocThreadCreator", fields: [createdById], references: [id])
  comments  DocComment[]

  @@index([docId, resolved])
  @@map("doc_comment_threads")
}

/// Single reply within a DocCommentThread
model DocComment {
  id        String    @id @default(uuid())
  threadId  String    @map("thread_id")
  authorId  String    @map("author_id")
  body      String
  editedAt  DateTime? @map("edited_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  thread DocCommentThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User             @relation("DocCommentAuthor", fields: [authorId], references: [id])

  @@index([threadId, createdAt])
  @@map("doc_comments")
}

/// Public share link — time-limited, role-scoped, revocable
model DocShareLink {
  id          String    @id @default(uuid())
  docId       String    @map("doc_id")
  token       String    @unique
  role        DocRole // VIEWER or COMMENTER only
  expiresAt   DateTime? @map("expires_at")
  createdById String    @map("created_by_id")
  revokedAt   DateTime? @map("revoked_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relations
  doc       Doc  @relation(fields: [docId], references: [id], onDelete: Cascade)
  createdBy User @relation("DocShareLinkCreator", fields: [createdById], references: [id])

  @@index([docId])
  @@map("doc_share_links")
}
